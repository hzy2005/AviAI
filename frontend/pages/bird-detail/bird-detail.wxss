.page {
  min-height: 100vh;
  background: #f2f2f2;
  padding-bottom: 34rpx;
}

.nav {
  width: 100%;
}

.nav-inner {
  height: 88rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-placeholder {
  opacity: 0;
}

.nav-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.hero-wrap {
  margin-top: 8rpx;
}

.hero-swiper,
.hero-empty {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(130deg, #7890ac, #d0b778);
}

.hero-image {
  width: 100%;
  height: 100%;
}

.title {
  margin-top: 26rpx;
  padding: 0 48rpx;
  font-size: 58rpx;
  line-height: 1.16;
  color: #0f1620;
  font-weight: 700;
}

.subtitle {
  margin-top: 10rpx;
  padding: 0 48rpx;
  font-size: 28rpx;
  color: #586574;
}

.info-list {
  margin-top: 24rpx;
  padding: 0 48rpx 12rpx;
}

.info-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2e5ea;
}

.label {
  font-size: 23rpx;
  color: #748293;
}

.value {
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.55;
  color: #15202c;
  white-space: pre-wrap;
  word-break: break-word;
}

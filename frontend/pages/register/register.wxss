.auth-page {
  min-height: 100vh;
  background: #f6f6f3;
  position: relative;
  overflow: hidden;
}

.hero {
  position: relative;
  height: 404rpx;
  background: #2f7d57;
  padding: 18rpx 0 0;
  overflow: hidden;
}

.title-block {
  position: absolute;
  left: 28rpx;
  top: 160rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.title-line {
  font-size: 50rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.hero-bird-wrap {
  position: absolute;
  right: 80rpx;
  top: 30rpx;
  width: 430rpx;
  height: 430rpx;
  z-index: 1;
}

.hero-bird {
  width: 120%;
  height: 120%;
}

.card {
  position: relative;
  z-index: 2;
  margin-top: -60rpx;
  background: #f7f7f4;
  border-radius: 68rpx 68rpx 0 0;
  min-height: calc(100vh - 328rpx);
  padding: 48rpx 26rpx 300rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.field-wrap {
  position: relative;
  margin-bottom: 56rpx;
}

.field {
  width: 100%;
  height: 96rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e9e9e6;
  padding: 0 78rpx 0 48rpx;
  box-sizing: border-box;
  background: #fdfdfc;
  font-size: 31rpx;
  color: #181818;
}

.field-placeholder {
  color: #1f1f1f;
  font-size: 31rpx;
}

.field-icon {
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

.field-wrap,
.btn-wrap {
  width: 100%;
  box-sizing: border-box;
}

.btn-wrap {
  margin-top: 20rpx;
}

.primary-btn {
  display: block;
  width: 100% !important;
  height: 90rpx;
  padding: 0 !important;
  margin: 0 !important;
  border: none;
  border-radius: 12rpx;
  box-sizing: border-box;
  background: #030303;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  line-height: 90rpx;
  box-shadow: 0 18rpx 28rpx rgba(0, 0, 0, 0.14);
}

.primary-btn::after {
  border: none;
}

.switch-row {
  margin-top: 44rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.2;
}

.switch-tip {
  color: #acacac;
}

.switch-link {
  color: #111111;
  font-weight: 700;
  margin-left: 4rpx;
}

.wave-wrap {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 20rpx;
  height: 200rpx;
  z-index: 3;
  pointer-events: none;
}

.wave-svg {
  position: absolute;
  width: 150%;
  left: 50%;
  transform: translateX(-50%);
}

.wave-back {
  bottom: -800rpx;
  opacity: 0.8;
}

.wave-front {
  bottom: -20rpx;
}

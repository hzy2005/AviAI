<view class="page">
  <view class="hero {{backgroundImage ? 'has-image' : ''}}">
    <image wx:if="{{backgroundImage}}" class="hero-bg" src="{{backgroundImage}}" mode="aspectFill" />
    <image wx:else class="hero-bg" src="/static/view/Homepage Background.jpg" mode="aspectFill" />
    <view wx:if="{{backgroundImage}}" class="hero-mask"></view>

    <view wx:if="{{recognized}}" class="tag-bar" bindtap="onOpenBirdDetail">
      <view>
        <view class="tag-sub">Bird recognized</view>
        <view class="tag-title">{{recognized.birdName}}</view>
      </view>
      <view class="info">i</view>
    </view>

    <view class="sheet">
      <view class="welcome">Welcome back!</view>
      <view class="headline">Find Nature's Scenery</view>

      <button class="record-btn" loading="{{loading}}" bindtap="onStartRecording">
        <text class="red-dot"></text>
        <text>Start recording</text>
      </button>

      <view class="quick-row">
        <view class="quick-item" bindtap="onSelectPhoto">Photo</view>
        <view class="quick-item {{isMyBird ? 'active' : ''}}" bindtap="onMarkAsMyBird">
          {{isMyBird ? 'Added!' : 'I saw it!'}}
        </view>
      </view>
    </view>
  </view>
</view>

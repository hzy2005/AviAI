.page {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
  background: #f2f4f2;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  border-radius: 0;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.hero-bg,
.hero-mask {
  position: absolute;
  inset: 0;
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.26));
}

.tag-bar {
  position: relative;
  z-index: 2;
  margin-top: 100rpx;
  border-radius: 24rpx;
  background: #232833;
  color: #f6f8fb;
  padding: 18rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tag-sub {
  font-size: 30rpx;
  color: #afbac8;
}

.tag-title {
  margin-top: 10rpx;
  font-size: 50rpx;
  font-weight: 600;
}

.info {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  line-height: 34rpx;
  text-align: center;
  border: 1px solid #8c97a6;
  color: #d5dce8;
  font-size: 20rpx;
}

.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  min-height: 300rpx;
  border-radius: 80rpx 80rpx 0 0;
  background: linear-gradient(
    180deg,
    rgba(246, 247, 245, 0.1) 0%,
    rgba(246, 247, 245, 0.5) 48%,
    rgba(255, 255, 255, 1) 100%
  );
  backdrop-filter: blur(10px);
  padding: 42rpx 24rpx calc(34rpx + env(safe-area-inset-bottom));
}

.welcome {
  text-align: center;
  color: #2f8e63;
  font-size: 34rpx;
  font-weight: 500;
}

.headline {
  margin-top: 10rpx;
  text-align: center;
  color: #2d3032;
  font-size: 62rpx;
  font-weight: 700;
  line-height: 1.08;
}

.record-btn {
  margin: 24rpx 0 0 0;
  border-radius: 999rpx;
  background: #3f3f44;
  color: #ffffff;
  font-size: 30rpx;
  width: 100%;
  max-width: 100%;
  min-width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.record-btn::after {
  border: none;
}

.red-dot {
  display: inline-block;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ff4a4a;
}

.quick-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.quick-item {
  flex: 1;
  border-radius: 999rpx;
  background: rgba(233, 236, 233, 0.78);
  color: #525a55;
  text-align: center;
  height: 96rpx;
  line-height: 96rpx;
  box-sizing: border-box;
  font-size: 30rpx;
}

.quick-item.active {
  background: rgba(223, 242, 231, 0.85);
  color: #24734f;
  font-weight: 600;
}

.hint {
  margin-top: 24rpx;
  text-align: center;
  color: #6f7c74;
  font-size: 24rpx;
}

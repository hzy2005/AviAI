.page {
  min-height: 100vh;
  background: #f2f2f2;
}

.profile-wrap {
  padding-bottom: 28rpx;
}

.hero {
  position: relative;
  width: 100%;
  height: 430rpx;
  overflow: hidden;
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.36));
}

.avatar-wrap {
  width: 100%;
  margin-top: -90rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 3;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  border: 6rpx solid #ffffff;
  background: #d9dde1;
}

.name {
  margin-top: 18rpx;
  text-align: center;
  font-size: 58rpx;
  color: #2e805a;
  font-weight: 700;
}

.email {
  margin-top: 8rpx;
  text-align: center;
  font-size: 30rpx;
  color: #21262d;
}

.actions {
  margin-top: 20rpx;
  padding: 0 32rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1e242e;
  font-size: 27rpx;
  border: 1rpx solid #dde3eb;
}

.logout-btn {
  color: #ffffff;
  background: #c65f53;
  border: 1rpx solid #c65f53;
}

.records-title {
  margin-top: 24rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #202734;
}

.masonry {
  margin-top: 16rpx;
  padding: 0 32rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.post-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #d9dde1;
}

.post-card.large {
  height: 390rpx;
}

.post-card.medium {
  height: 320rpx;
}

.post-card.tall {
  height: 470rpx;
}

.post-image {
  width: 100%;
  height: 100%;
}

.placeholder {
  background: linear-gradient(140deg, #8d95b2, #d8ddd6);
}

.overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 52%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.62));
}

.card-meta {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 16rpx;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.views {
  font-size: 20rpx;
  opacity: 0.92;
}

.name-text {
  font-size: 38rpx;
  line-height: 1.08;
  font-weight: 700;
}

.empty-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty {
  text-align: center;
  color: #8a9590;
  font-size: 24rpx;
  padding: 20rpx 0;
}

.login-btn {
  margin-top: 12rpx;
  border-radius: 12rpx;
  background: #2f825c;
  color: #ffffff;
  font-size: 26rpx;
}

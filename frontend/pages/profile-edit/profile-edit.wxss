.page {
  min-height: 100vh;
  background: #f6f6f3;
}

.top-bar {
  width: 100%;
  background: #ffffff;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 30rpx;
  height: 30rpx;
}

.content {
  background: #f7f7f4;
  border-radius: 68rpx 68rpx 0 0;
  min-height: calc(100vh - 88rpx);
  margin-top: 16rpx;
  padding: 48rpx 26rpx 140rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.avatar-wrap {
  width: 188rpx;
  height: 188rpx;
  margin: 0 auto 56rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #d8dce2;
}

.avatar {
  width: 100%;
  height: 100%;
}

.field-wrap {
  position: relative;
  margin-bottom: 56rpx;
  width: 100%;
  box-sizing: border-box;
}

.field {
  width: 100%;
  height: 96rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e9e9e6;
  padding: 0 78rpx 0 48rpx;
  box-sizing: border-box;
  background: #fdfdfc;
  font-size: 31rpx;
  color: #181818;
}

.field-placeholder {
  color: #1f1f1f;
  font-size: 31rpx;
}

.field-icon {
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

.btn-wrap {
  width: 100%;
  box-sizing: border-box;
  margin-top: 20rpx;
}

.secondary-wrap {
  margin-top: 22rpx;
}

.primary-btn,
.secondary-btn {
  display: block;
  width: 100% !important;
  height: 90rpx;
  padding: 0 !important;
  margin: 0 !important;
  border: none;
  border-radius: 12rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  line-height: 90rpx;
}

.primary-btn {
  background: #030303;
  color: #ffffff;
  box-shadow: 0 18rpx 28rpx rgba(0, 0, 0, 0.14);
}

.secondary-btn {
  background: #ffffff;
  color: #111111;
  border: 2rpx solid #e9e9e6;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

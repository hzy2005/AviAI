.page {
  min-height: 100vh;
  background: #ececec;
}

.top-bar {
  width: 100%;
  background: #2f815a;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 30rpx;
  height: 30rpx;
}

.content {
  padding: 60rpx;
  box-sizing: border-box;
}

.avatar-wrap {
  width: 188rpx;
  height: 188rpx;
  margin: 0 auto 56rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #d8dce2;
}

.avatar {
  width: 100%;
  height: 100%;
}

.field-wrap {
  margin-bottom: 24rpx;
}

.field {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  border: 1rpx solid #3d9876;
  background: #ececec;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 29rpx;
  color: #20242d;
}

.field-placeholder {
  color: #888f96;
  font-size: 29rpx;
}

.password-wrap {
  position: relative;
}

.password-field {
  padding-right: 108rpx;
}

.show-text {
  position: absolute;
  top: 50%;
  right: 20rpx;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #7f868d;
}

.done-btn,
.cancel-btn {
  width: 100% !important;
  display: block;
  padding: 0;
  margin-left: 0 !important;
  margin-right: 0 !important;
  height: 80rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  font-size: 38rpx;
  font-weight: 600;
  text-align: center;
  line-height: 80rpx;
}

.done-btn::after,
.cancel-btn::after {
  border: none;
}

.done-btn {
  margin-top: 44rpx;
  background: #2f815a;
  color: #ffffff;
}

.cancel-btn {
  margin-top: 22rpx;
  background: #f2f2f2;
  color: #2f815a;
  border: 1rpx solid #3d9876;
}

# Docker Compose environment template
#
# Copy this file to .env for local Docker runs, then fill in real values.
# Do not commit .env or production secret files.

# Optional AI service configuration used by backend compose services.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VISION_MODEL=deepseek-chat

# Production image selection for compose.prod.yaml.
# Example:
# GITHUB_REPOSITORY=hzy2005/AviAI
# VERSION=latest
GITHUB_REPOSITORY=
VERSION=latest

# Production secrets are intentionally not stored in .env.
# Create these files locally before running compose.prod.yaml:
# - secrets/db_password.txt
# - secrets/db_root_password.txt
# - secrets/backend_secret_key.txt
